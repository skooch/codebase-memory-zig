{
  "schema_version": "0.2",
  "goal": "Pinned GitHub benchmark corpus for larger, mature repositories across supported languages",
  "repos": [
    {
      "id": "flask",
      "project": "flask-3-1-3",
      "warmup_runs": 0,
      "measured_runs": 1,
      "github": {
        "repo": "pallets/flask",
        "ref": "3.1.3"
      },
      "notes": [
        "Pinned to Flask 3.1.3 from GitHub releases.",
        "Uses agent-style search and snippet prompts so the benchmark stays stable across a larger Python repo."
      ],
      "accuracy_scenarios": [
        {
          "id": "find-flask-class",
          "tool": "search_code",
          "args": {
            "pattern": "class Flask",
            "mode": "compact",
            "limit": 10
          },
          "expect": {
            "required_names": [
              "Flask"
            ],
            "required_files": [
              "src/flask/app.py"
            ],
            "required_keys": [
              "results",
              "total"
            ]
          }
        },
        {
          "id": "open-wsgi-app",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name_hint": "wsgi_app"
          },
          "expect": {
            "required_substrings": [
              "ctx.push()",
              "self.full_dispatch_request()"
            ],
            "required_keys": [
              "source",
              "file_path"
            ]
          }
        },
        {
          "id": "architecture-summary",
          "tool": "get_architecture",
          "args": {
            "aspects": [
              "packages",
              "hotspots"
            ]
          },
          "expect": {
            "required_keys": [
              "project",
              "packages",
              "hotspots"
            ]
          }
        }
      ],
      "performance_scenarios": [
        {
          "id": "find-flask-class",
          "tool": "search_code",
          "args": {
            "pattern": "class Flask",
            "mode": "compact",
            "limit": 10
          }
        },
        {
          "id": "open-wsgi-app",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name_hint": "wsgi_app"
          }
        },
        {
          "id": "architecture-summary",
          "tool": "get_architecture",
          "args": {
            "aspects": [
              "packages",
              "hotspots"
            ]
          }
        }
      ]
    },
