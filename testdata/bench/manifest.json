        {
          "id": "function-search",
          "tool": "search_graph",
          "args": {
            "label": "Function"
          },
          "expect": {
            "required_names": [
              "main",
              "helper"
            ]
          }
        },
        {
          "id": "function-count",
          "tool": "query_graph",
          "args": {
            "query": "MATCH (n) WHERE n.label = \"Function\" RETURN count(n) AS count",
            "max_rows": 20
          },
          "expect": {
            "columns": [
              "count"
            ],
            "required_rows_min": 1
          }
        },
        {
          "id": "trace-main",
          "tool": "trace_call_path",
          "args": {
            "start_node_name_hint": "main",
            "direction": "out",
            "depth": 3
