{
  "schema_version": "0.1",
  "goal": "Shared agent comparison tasks for the local worktree-scale repository",
  "repos": [
    {
      "id": "worktree-medium",
      "path": ".",
      "project": "agent-session-parity",
      "warmup_runs": 1,
      "measured_runs": 1,
      "notes": [
        "Local worktree scenario to validate a recorded explorer session on a larger repository.",
        "The final step intentionally requests a missing symbol so the report compares shared error behavior instead of only successful lookups."
      ],
      "tasks": [
        {
          "id": "find-query-router",
          "prompt": "Use the codebase explorer to find the QueryRouter symbol that fronts the query routing path.",
          "tool": "search_graph",
          "args": {
            "name_pattern": "QueryRouter",
            "limit": 10
          },
          "expect": {
            "required_names": [
              "QueryRouter"
            ],
            "required_files": [
              "src/query_router.zig"
            ]
          }
        },
        {
          "id": "open-search-code-payload",
          "prompt": "Open the QueryRouter searchCodePayload implementation.",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name": "searchCodePayload"
          },
          "expect": {
            "required_substrings": [
              "pub fn searchCodePayload",
              "collectSearchCodeHits"
            ],
            "required_keys": [
              "source",
              "file_path"
            ]
          }
        },
        {
          "id": "trace-search-code-payload",
          "prompt": "Trace the call path around searchCodePayload to confirm how the query router reaches it.",
          "tool": "trace_call_path",
          "args": {
            "start_node_name_hint": "searchCodePayload",
            "direction": "inbound",
            "depth": 1
          },
          "expect": {
            "required_substrings": [
              "searchCodePayload"
            ]
          }
        },
        {
          "id": "summarize-architecture",
          "prompt": "Summarize the architecture with packages, hotspots, and entry points.",
          "tool": "get_architecture",
          "args": {
            "aspects": [
              "packages",
              "hotspots",
              "entry_points"
            ]
          },
          "expect": {
            "required_keys": [
              "project",
              "packages",
              "hotspots",
              "entry_points"
            ]
          }
        },
        {
          "id": "missing-symbol-error",
          "prompt": "Try to open a missing symbol and record the error for parity comparison.",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name": "definitelyMissingSymbolForParity"
          },
          "expect": {
            "expect_error": true
          }
        }
      ]
    }
  ]
}
