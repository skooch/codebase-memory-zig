{
  "schema_version": "0.1",
  "goal": "Shared agent comparison tasks for the SCIP overlay fixture",
  "repos": [
    {
      "id": "scip-overlay",
      "path": "testdata/interop/scip",
      "project": "scip",
      "warmup_runs": 1,
      "measured_runs": 2,
      "tasks": [
        {
          "id": "find-render-message",
          "prompt": "Find the renderMessage symbol in the repository.",
          "tool": "search_code",
          "args": {
            "pattern": "renderMessage",
            "mode": "compact",
            "limit": 10
          },
          "expect": {
            "required_names": [
              "renderMessage"
            ],
            "required_files": [
              "src/main.ts"
            ],
            "required_keys": [
              "results",
              "total"
            ]
          }
        },
        {
          "id": "open-render-message",
          "prompt": "Open the renderMessage implementation.",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name": "renderMessage"
          },
          "expect": {
            "required_substrings": [
              "toUpperCase",
              "hello ${name}"
            ],
            "required_keys": [
              "source",
              "file_path"
            ]
          }
        },
        {
          "id": "summarize-architecture",
          "prompt": "Describe the repository layout and graph summary.",
          "tool": "get_architecture",
          "args": {
            "aspects": [
              "packages",
              "hotspots"
            ]
          },
          "expect": {
            "required_keys": [
              "project",
              "packages",
              "hotspots"
            ]
          }
        }
      ]
    }
  ]
}
