{
  "schema_version": "0.2",
  "goal": "Pinned GitHub agent-comparison suites for larger mature repositories",
  "repos": [
    {
      "id": "flask",
      "project": "flask-3-1-3",
      "warmup_runs": 0,
      "measured_runs": 1,
      "github": {
        "repo": "pallets/flask",
        "ref": "3.1.3"
      },
      "notes": [
        "Pinned GitHub suite for Flask 3.1.3."
      ],
      "tasks": [
        {
          "id": "find-flask-class",
          "prompt": "Find the main Flask application class in the repository.",
          "tool": "search_code",
          "args": {
            "pattern": "class Flask",
            "mode": "compact",
            "limit": 10
          },
          "expect": {
            "required_names": [
              "Flask"
            ],
            "required_files": [
              "src/flask/app.py"
            ],
            "required_keys": [
              "results",
              "total"
            ]
          }
        },
        {
          "id": "open-wsgi-app",
          "prompt": "Open the Flask wsgi_app implementation.",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name_hint": "wsgi_app"
          },
          "expect": {
            "required_substrings": [
              "ctx.push()",
              "self.full_dispatch_request()"
            ],
            "required_keys": [
              "source",
              "file_path"
            ]
          }
        },
        {
          "id": "summarize-architecture",
          "prompt": "Summarize the repository architecture with packages and hotspots.",
          "tool": "get_architecture",
          "args": {
            "aspects": [
              "packages",
              "hotspots"
            ]
          },
          "expect": {
            "required_keys": [
              "project",
              "packages",
              "hotspots"
            ]
          }
        }
      ]
    },
    {
      "id": "zls",
      "project": "zls-0-16-0",
      "warmup_runs": 0,
      "measured_runs": 1,
      "github": {
        "repo": "zigtools/zls",
        "ref": "0.16.0"
      },
      "notes": [
        "Pinned GitHub suite for zls 0.16.0."
      ],
      "tasks": [
        {
          "id": "find-hover",
          "prompt": "Find the hover feature implementation in zls.",
          "tool": "search_code",
          "args": {
            "pattern": "pub fn hover",
            "mode": "compact",
            "limit": 10
          },
          "expect": {
            "required_names": [
              "hover"
            ],
            "required_files": [
              "src/features/hover.zig"
            ],
            "required_keys": [
              "results",
              "total"
            ]
          }
        },
        {
          "id": "open-hover",
          "prompt": "Open the zls hover implementation.",
          "tool": "get_code_snippet",
          "args": {
            "qualified_name_hint": "hover"
          },
          "expect": {
            "required_substrings": [
              "Analyser.getPositionContext",
              "hoverDefinitionFieldAccess"
            ],
            "required_keys": [
              "source",
              "file_path"
            ]
          }
        },
        {
          "id": "summarize-architecture",
          "prompt": "Summarize the repository architecture with packages, hotspots, and entry points.",
          "tool": "get_architecture",
          "args": {
            "aspects": [
              "packages",
              "hotspots",
              "entry_points"
            ]
          },
          "expect": {
            "required_keys": [
              "project",
              "packages",
              "hotspots",
              "entry_points"
            ]
          }
        }
      ]
    }
  ]
}
